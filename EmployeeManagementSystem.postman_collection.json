{
  "info": {
    "name": "Employee Management System API Collection",
    "description": "Postman Collection for the Spring Boot Employee Management System REST API.\nContains endpoints for managing Employees, Attendance, Leaves, and Tasks with proper validation, status codes, and JSON response formats.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Employee Module",
      "item": [
        {
          "name": "Add Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"+12345678901\",\n  \"department\": \"Engineering\",\n  \"designation\": \"Software Engineer\",\n  \"joiningDate\": \"2026-07-01\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/employees",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees"
              ]
            },
            "description": "Create a new employee record. The email must be unique, and the phone must be a valid 10-15 digit phone number."
          }
        },
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/employees",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees"
              ]
            },
            "description": "Retrieve a list of all employees."
          }
        },
        {
          "name": "Get Employee By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/employees/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees",
                "1"
              ]
            },
            "description": "Retrieve details of a single employee by their ID."
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe Jr.\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"+19876543210\",\n  \"department\": \"Engineering\",\n  \"designation\": \"Senior Software Engineer\",\n  \"joiningDate\": \"2026-07-01\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/employees/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees",
                "1"
              ]
            },
            "description": "Update details of an existing employee by ID."
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/employees/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees",
                "1"
              ]
            },
            "description": "Delete an employee record from the system."
          }
        },
        {
          "name": "Search Employee By Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/employees/search/name?name=John",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees",
                "search",
                "name"
              ],
              "query": [
                {
                  "key": "name",
                  "value": "John"
                }
              ]
            },
            "description": "Search employees whose name contains the search string (case-insensitive)."
          }
        },
        {
          "name": "Search Employee By Department",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/employees/search/department?department=Engineering",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "employees",
                "search",
                "department"
              ],
              "query": [
                {
                  "key": "department",
                  "value": "Engineering"
                }
              ]
            },
            "description": "Search employees by department name."
          }
        }
      ]
    },
    {
