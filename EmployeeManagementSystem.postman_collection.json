              ]
            },
            "description": "Log check-out event for employee today. Automatically calculates duration (workingHours)."
          }
        }
      ]
    },
    {
      "name": "Leave Module",
      "item": [
        {
          "name": "Apply Leave Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": 1,\n  \"leaveType\": \"Sick Leave\",\n  \"fromDate\": \"2026-07-10\",\n  \"toDate\": \"2026-07-12\",\n  \"reason\": \"Medical treatment for fever\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/leaves",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "leaves"
              ]
            },
            "description": "Submit a leave request. Dates must be chronological. Status is set to 'Pending' by default."
          }
        },
        {
          "name": "Get All Leaves",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/leaves",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "leaves"
              ]
            },
            "description": "Retrieve list of all leaves."
          }
        },
        {
          "name": "Get Leave By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/leaves/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "leaves",
                "1"
              ]
            },
            "description": "Retrieve details of a leave request by ID."
