              "raw": "{\n  \"employeeId\": 1,\n  \"title\": \"Implement Authentication\",\n  \"description\": \"Set up JWT based authentication system in application.\",\n  \"priority\": \"High\",\n  \"dueDate\": \"2026-07-15\"\n}"
