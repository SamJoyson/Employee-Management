          "name": "Check-In Employee (Current Date/Time)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/attendance/checkin/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "attendance",
                "checkin",
                "1"
              ]
            },
            "description": "Log check-in event for employee today. Determines status ('Present' or 'Late' depending on late-limit 09:15)."
          }
        },
        {
          "name": "Check-Out Employee (Current Date/Time)",
          "request": {
            "method": "POST",
            "header": [],
