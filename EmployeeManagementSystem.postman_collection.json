              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": 1,\n  \"leaveType\": \"Casual Leave\",\n  \"fromDate\": \"2026-07-10\",\n  \"toDate\": \"2026-07-11\",\n  \"reason\": \"Family function\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/leaves/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "leaves",
                "1"
              ]
            },
            "description": "Modify leave request parameters prior to approval."
          }
        },
        {
          "name": "Approve Leave",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{base_url}}/leaves/1/approve",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "leaves",
                "1",
                "approve"
              ]
            },
            "description": "Approve a leave request. Status will change from Pending to Approved."
